{
  "name": "ChipCraft Lab",
  "image": "ghcr.io/narrave/chipcraft:latest",
  "overrideCommand": false,
  "mounts": [
    "type=tmpfs,destination=/home/ubuntu/lab/.build,tmpfs-size=2147483648,tmpfs-mode=1777"
  ],
  "forwardPorts": [6080],
  "portsAttributes": {
    "6080": {
      "label": "Lab Desktop",
      "onAutoForward": "openBrowser",
      "protocol": "http"
    }
  },
  "remoteUser": "ubuntu",
  "postAttachCommand": "bash /workspaces/chipcraft-student/.devcontainer/setup.sh"
}
