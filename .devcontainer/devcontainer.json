{
  "name": "ChipCraft Lab",
  "image": "ghcr.io/narrave/chipcraft:latest",
  "overrideCommand": false,
  "runArgs": [
    "--tmpfs", "/home/ubuntu/lab/build:rw,exec,size=2g,uid=1000,gid=1000,mode=0700"
  ],
  "forwardPorts": [6080],
  "portsAttributes": {
    "6080": {
      "label": "Lab Desktop",
      "onAutoForward": "openBrowser",
      "protocol": "http"
    }
  },
  "remoteUser": "ubuntu",
  "postAttachCommand": "bash /workspaces/chipcraft-student/.devcontainer/setup.sh"
}
